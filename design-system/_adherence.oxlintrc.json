{
  "plugins": [
    "react",
    "import"
  ],
  "rules": {
    "react/forbid-elements": [
      "warn",
      {
        "forbid": []
      }
    ],
    "no-restricted-imports": [
      "warn",
      {
        "patterns": [
          {
            "group": [
              "components/core/**",
              "ui_kits/booth/**",
              "ui_kits/dashboard/**",
              "ui_kits/onboarding/**",
              "ui_kits/pwa/**"
            ],
            "message": "Import design-system components from 'index.js', not component internals."
          }
        ]
      }
    ],
    "no-restricted-syntax": [
      "warn",
      {
        "selector": "Literal[value=/#[0-9a-fA-F]{3,8}\\b/]",
        "message": "Raw hex color — use a design-system color token via var()."
      },
      {
        "selector": "Literal[value=/\\b\\d+px\\b/]",
        "message": "Raw px value — use a design-system spacing token via var()."
      },
      {
        "selector": "Literal[value=/font-family\\s*:\\s*(?!['\\\"]?(?:Plus Jakarta Sans|JetBrains Mono))/i]",
        "message": "Font not provided by the design system. Available: Plus Jakarta Sans, JetBrains Mono."
      },
      {
        "selector": "JSXOpeningElement[name.name='Badge'] > JSXAttribute > JSXIdentifier[name!=/^(?:variant|key|ref|className|style|children)$/]",
        "message": "<Badge> doesn't accept that prop. Declared props: variant."
      },
      {
        "selector": "JSXOpeningElement[name.name='BoothButton'] > JSXAttribute > JSXIdentifier[name!=/^(?:variant|key|ref|className|style|children)$/]",
        "message": "<BoothButton> doesn't accept that prop. Declared props: variant."
      },
      {
        "selector": "JSXOpeningElement[name.name='BoothButton'] > JSXAttribute[name.name='variant'] > Literal[value!=/^(?:primary|outline|danger)$/]",
        "message": "<BoothButton> variant must be one of 'primary' | 'outline' | 'danger'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute > JSXIdentifier[name!=/^(?:variant|size|key|ref|className|style|children)$/]",
        "message": "<Button> doesn't accept that prop. Declared props: variant, size."
      },
      {
        "selector": "JSXOpeningElement[name.name='Card'] > JSXAttribute > JSXIdentifier[name!=/^(?:glow|key|ref|className|style|children)$/]",
        "message": "<Card> doesn't accept that prop. Declared props: glow."
      },
      {
        "selector": "JSXOpeningElement[name.name='Logo'] > JSXAttribute > JSXIdentifier[name!=/^(?:size|color|wordmark|wordmarkColor|key|ref|className|style|children)$/]",
        "message": "<Logo> doesn't accept that prop. Declared props: size, color, wordmark, wordmarkColor."
      },
      {
        "selector": "JSXOpeningElement[name.name='MetricCard'] > JSXAttribute > JSXIdentifier[name!=/^(?:label|value|delta|deltaColor|icon|style|key|ref|className|style|children)$/]",
        "message": "<MetricCard> doesn't accept that prop. Declared props: label, value, delta, deltaColor, icon, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='MetricCard'] > JSXAttribute[name.name='deltaColor'] > Literal[value!=/^(?:up|down|muted)$/]",
        "message": "<MetricCard> deltaColor must be one of 'up' | 'down' | 'muted'."
      },
      {
        "selector": "JSXOpeningElement[name.name='PlateDisplay'] > JSXAttribute > JSXIdentifier[name!=/^(?:plate|size|key|ref|className|style|children)$/]",
        "message": "<PlateDisplay> doesn't accept that prop. Declared props: plate, size."
      },
      {
        "selector": "JSXOpeningElement[name.name='PlateDisplay'] > JSXAttribute[name.name='size'] > Literal[value!=/^(?:sm|md|lg)$/]",
        "message": "<PlateDisplay> size must be one of 'sm' | 'md' | 'lg'."
      },
      {
        "selector": "JSXOpeningElement[name.name='StatusBadge'] > JSXAttribute > JSXIdentifier[name!=/^(?:value|label|key|ref|className|style|children)$/]",
        "message": "<StatusBadge> doesn't accept that prop. Declared props: value, label."
      }
    ]
  },
  "overrides": [
    {
      "files": [
        "**/index.js"
      ],
      "rules": {
        "no-restricted-imports": "off"
      }
    }
  ],
  "x-omelette": {
