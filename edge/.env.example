# SupaPark edge — per-lane config. Copy to .env on the Raspberry Pi.

# Supabase (the "anon key" value is the project's publishable key).
EDGE_SUPABASE_URL=https://your-project.supabase.co
EDGE_SUPABASE_ANON_KEY=sb_publishable_xxx

# This lane's secret, taken from lanes.api_key for THIS lane (unique per lane).
EDGE_LANE_API_KEY=lane-specific-key

# Lane identity.
EDGE_LANE_ID=00000000-0000-0000-0000-000000000000
EDGE_LOCATION_ID=00000000-0000-0000-0000-000000000000   # informational; location is derived from the lane key
EDGE_LANE_MODE=exit                                       # entry | exit

# Hardware.
EDGE_ALPR_MOCK=false      # true uses the built-in mock plate source
EDGE_RELAY_TYPE=gpio      # gpio | stub

# Optional overrides (defaults shown).
# EDGE_HTTP_ADDR=:8080
# EDGE_BOLT_PATH=/var/lib/supapark/edge.db
# EDGE_FIRMWARE_VERSION=1.0.0
# EDGE_SYNC_INTERVAL=15s
# EDGE_HEARTBEAT_INTERVAL=30s
